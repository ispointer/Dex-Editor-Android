<resources>
	<style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
		<item name="colorPrimary">#303030</item>
		<item name="colorPrimaryDark">#303030</item>
		<item name="colorAccent">#2196F3</item>
		<item name="android:statusBarColor">?attr/colorPrimaryDark</item>
		<item name="android:navigationBarColor">#FFFFFF</item>
		<item name="colorOnSurface">#000000</item>
		<item name="alertDialogTheme">@style/MTDialogTheme</item>
	</style>

	<style name="MTDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
		<item name="android:windowBackground">@android:color/transparent</item>
		<item name="android:background">#FFFFFF</item>
		<item name="android:textColor">#000000</item>
		<item name="android:textColorPrimary">#000000</item>
		<item name="colorAccent">#2196F3</item>
		<item name="android:windowMinWidthMajor">90%</item>
		<item name="android:windowMinWidthMinor">90%</item>
		<item name="buttonBarPositiveButtonStyle">@style/MTDialogButton</item>
		<item name="buttonBarNegativeButtonStyle">@style/MTDialogButton</item>
		<item name="buttonBarNeutralButtonStyle">@style/MTDialogButton</item>
	</style>

	<style name="MTDialogButton" parent="Widget.AppCompat.Button.Borderless.Colored">
		<item name="android:textColor">#2196F3</item>
		<item name="android:textSize">14sp</item>
		<item name="android:textAllCaps">true</item>
		<item name="android:textStyle">bold</item>
		<item name="android:paddingLeft">16dp</item>
		<item name="android:paddingRight">16dp</item>
	</style>
	<style name="AppTheme.FullScreen" parent="AppTheme">
		<item name="android:windowFullscreen">true</item>
		<item name="android:windowContentOverlay">@null</item>
	</style>
	<style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
	<style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
	<style name="AppTheme.DebugActivity" parent="AppTheme">
		<item name="actionBarStyle">@style/Widget.AppCompat.ActionBar</item>
		<item name="actionBarTheme">@style/ThemeOverlay.AppCompat.ActionBar</item>
		<item name="windowActionBar">true</item>
		<item name="windowNoTitle">false</item>
	</style>
	<style name="text_action_popup_animation">
		<item name="android:windowEnterAnimation">@anim/anim_text_action_popup_enter</item>
		<item name="android:windowExitAnimation">@anim/anim_text_action_popup_exit</item>
	</style>
	<style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
		<item name="android:textStyle">normal</item>
	</style>
	<style name="ToolbarSmallSubtitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Subtitle">
		<item name="android:textSize">10sp</item>
		<item name="textSize">10sp</item>
	</style>
</resources>
